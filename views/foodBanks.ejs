<%- include('partials/header', { title }) %>

<main class="container">
    <h1 class="outbg_text">Food bank services</h1>
    <p class="outbg_text">
        Discover food bank programs and support services available in your community.
    </p>

    <section class="grid">
        <article class="card">
            <h4>Emergency food hampers</h4>
            <p>Receive essential groceries and pantry staples during difficult times.</p>
        </article>

        <article class="card">
            <h4>Fresh produce distribution</h4>
            <p>Access fruits, vegetables, and other fresh food items.</p>
        </article>

        <article class="card">
            <h4>Mobile food banks</h4>
            <p>Food assistance delivered directly to neighborhoods and rural areas.</p>
        </article>

        <article class="card">
            <h4>School meal support</h4>
            <p>Programs that help provide meals and snacks for children and students.</p>
        </article>

        <article class="card">
            <h4>Senior food programs</h4>
            <p>Nutrition support and meal assistance tailored for older adults.</p>
        </article>

        <article class="card">
            <h4>Holiday meal programs</h4>
            <p>Special food hampers and community meals during holidays and celebrations.</p>
        </article>
    </section>
</main>

<%- include('partials/footer') %>