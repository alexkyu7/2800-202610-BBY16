<%- include('partials/header', { title }) %>

<main class="container">
    <h1 class="outbg_text">Food recycling services</h1>
    <p class="outbg_text">
        Learn about programs and initiatives that help reduce food waste and support sustainability.
    </p>

    <section class="grid">
        <article class="card">
            <h4>Composting programs</h4>
            <p>Turn food scraps and organic waste into nutrient-rich compost.</p>
        </article>

        <article class="card">
            <h4>Food donation services</h4>
            <p>Donate surplus food to shelters, food banks, and community organizations.</p>
        </article>

        <article class="card">
            <h4>Community fridge initiatives</h4>
            <p>Share unused food with neighbors through publicly accessible fridges.</p>
        </article>

        <article class="card">
            <h4>Restaurant surplus recovery</h4>
            <p>Programs that collect excess meals and ingredients from restaurants.</p>
        </article>

        <article class="card">
            <h4>Organic waste collection</h4>
            <p>Scheduled pickup services for food scraps and biodegradable materials.</p>
        </article>

        <article class="card">
            <h4>Education and awareness</h4>
            <p>Workshops and resources for reducing food waste at home and in communities.</p>
        </article>
    </section>
</main>

<%- include('partials/footer') %>