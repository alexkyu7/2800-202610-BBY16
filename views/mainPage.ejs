<%- include('partials/header', { title}) %>

<main class="container">
    <section class="hero">
        <div>
            <h1>Find food help fast</h1>
            <p>Discover food banks, community fridges, meal programs, and food recycling near you.</p>
            <div class="hero-actions">
                <a class="btn" href="/searchPage">Start searching</a>
                <a class="btn-outline" href="/mapPage">View map</a>
            </div>
        </div>
        <div class="hero-card">
            <h3>Quick search</h3>
            <label for="location">Location</label>
            <input id="location" type="text" placeholder="City or postal code">
            <label for="service">Service</label>
            <select id="service">
                <option>Food bank</option>
                <option>Meal program</option>
                <option>Community fridge</option>
                <option>Food recycling</option>
                <option>Other</option>
            </select>
            <button class="btn">Find now</button>
        </div>
    </section>

    <section class="grid">
        <article class="card">
            <h4>Food banks</h4>
            <p>Locate nearby pantries and pickup times.</p>
        </article>
        <article class="card">
            <h4>Meal programs</h4>
            <p>Hot meals from local community partners.</p>
        </article>
        <article class="card">
            <h4>Community fridges</h4>
            <p>24/7 access to shared food.</p>
        </article>
        <article class="card">
            <h4>Food recycling</h4>
            <p>Redistribute surplus food safely.</p>
        </article>
        <article class="card">
            <h4>Other services</h4>
            <p>Additional food support resources.</p>
        </article>
    </section>
</main>
<%- include('partials/footer') %>
