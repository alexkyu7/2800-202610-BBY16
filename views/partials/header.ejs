<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">

    <% if (typeof cssFiles !=='undefined' ) { %>
        <% cssFiles.forEach(function(cssFile) { %>
            <link rel="stylesheet" href="<%= cssFile %>">
        <% }); %>
    <% } %>
    <link rel="icon" href="/img/favicon.ico">
</head>

<body>
<header class="navbar">
    <div class="brand">
        <img src="/img/foodle_logo.png" alt="Foodle" id="egg-logo">
    </div>
    <nav class="desktop">
        <a href="/mainPage" class="active">Home</a>
        <a href="/searchPage">Search</a>
        <a href="/mapPage">Map</a>
        <a href="/cartPage">Cart</a>
        <a href="/accountPage">Account</a>
        <a href="/aiSearchPage">AI Search</a>

        <% if (isLoggedIn) { %>
            <a href="/logout" class="btn">Log out</a>
        <% } else { %>
            <a href="/loginPage" class="btn">Log in</a>
            <a href="/signUp" class="btn-outline">Sign up</a>
        <% } %>
    </nav>
    <div class="mobile">
        <% if (isLoggedIn) { %>
            <a href="/logout" class="btn">Log out</a>
        <% } else { %>
            <a href="/loginPage" class="btn">Log in</a>
            <a href="/signUp" class="btn-outline">Sign up</a>
        <% } %>
    </div>
    <!-- Easter Egg Modal -->
    <div id="egg-backdrop" aria-hidden="true"></div>
    <div id="egg-modal" role="dialog" aria-modal="true" aria-labelledby="egg-title">
        <div id="egg-inner">
            <div id="egg-header">
                <span id="egg-step-label">Secret Message</span>
                <button id="egg-close-btn" aria-label="Close">Close</button>
            </div>
            <h2 id="egg-title">You found it!</h2>
            <p id="egg-body"></p>
        </div>
    </div>

    <audio id="egg-audio" src="/audio/guitarSound.mp3" preload="auto"></audio>
    <script src="/js/easterEgg.js" defer></script>
</header>